{
  "expo": {
    "name": "MtgCounter",
    "slug": "mtgcounter",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mtgcounter",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.mtgcounter.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57220e70-39c1-4a95-9bf3-d7bf66eb9243"
      }
    }
  }
}
